{
  "type": "origins:multiple",

  "pressed": {
    "type": "origins:resource",
    "min": 0,
    "max": 3,
    "start_value": 0,
    "hud_render": {
      "should_render": false
    },

    "min_action":{
      "type": "origins:if_else",
      "condition": {
        "type": "apoli:resource",
        "resource": "pondspawn:tongue-pull_pressed",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:execute_command",
        "command": "changeTongue @s pull"
      },
      "else_action": {
        "type": "origins:execute_command",
        "command": "changeTongue @s lock"
      }
    }
  },

  "not-pressed": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "apoli:change_resource",
      "resource": "pondspawn:tongue-loose_pressed",
      "change": -1,
      "operation": "add"
    },
    "condition": {
      "type": "apoli:resource",
      "resource": "pondspawn:tongue-loose_pressed",
      "comparison": ">",
      "compare_to": 0
    }
  },

  "tick-shift": {
    "type": "origins:active_self",
    "entity_action": {
      "type": "apoli:change_resource",
      "resource": "pondspawn:tongue-loose_pressed",
      "change": 3,
      "operation": "set"
    },
    "key": {
      "key": "key.sneak",
      "continuous": true
    }
  },

  "loose": {
    "type": "origins:active_self",
    "entity_action": {
      "type": "origins:execute_command",
      "command": "changeTongue @s loose"
    },
    "key": {
      "key": "key.sneak",
      "continuous": false
    }
  },

  "hidden": true
}