{
  "type": "origins:multiple",

  "name": "§e§nSuper Jump",
  "description": "with your sturdy legs and enough preparation you can reach higher altitudes.",

  "badges": [
    {
      "type": "origins:keybind",
      "sprite": "origins:textures/gui/badge/active.png",
      "text": "Crouch and jump to activate"
    }
  ],


  "super-jump-resource": {
    "type": "origins:resource",
    "min": 0,
    "max": 80,
    "start_value": 0,
    "hud_render": {
      "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_03.png",
      "bar_index": 16,
      "condition": {
        "type": "origins:resource",
        "resource": "pondspawn:super-jump_super-jump-resource",
        "comparison": "!=",
        "compare_to": 0
      }
    },
    "max_action": {
      "type": "pondspawn:execute_commands",
      "commands": [
        "playsound minecraft:block.note_block.chime",
        "particle minecraft:happy_villager ~ ~1 ~ 1 1 1 10 40 normal"
      ]
    }
  },

  "zero-jump-resource": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "pondspawn:super-jump_super-jump-resource",
      "operation": "set",
      "change": 0
    },
    "condition": {
      "type": "apoli:all_of",
      "conditions": [
        {
          "type": "apoli:any_of",
          "conditions": [
            {
              "type": "origins:sneaking",
              "inverted": true
            },
            {
              "type": "origins:nbt",
              "nbt": "{OnGround:0b}"
            }
          ]
        },
        {
          "type": "origins:resource",
          "resource": "pondspawn:super-jump_super-jump-resource",
          "comparison": "!=",
          "compare_to": 0
        }
      ]
    }
  },

  "input-forgiveness": {
    "type": "origins:resource",
    "max": 10,
    "min": 0,
    "start_value": 0,
    "hud_render": {
      "should_render": false
    }
  },

  "remove-input-forgiveness": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "pondspawn:super-jump_input-forgiveness",
      "operation": "add",
      "change": -1
    },
    "condition": {
      "type": "apoli:all_of",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "pondspawn:super-jump_input-forgiveness",
          "comparison": "!=",
          "compare_to": 0
        },
        {
          "type": "apoli:any_of",
          "conditions": [
            {
              "type": "origins:sneaking",
              "inverted": true
            },
            {
              "type": "origins:nbt",
              "nbt": "{OnGround:0b}"
            }
          ]
        }
      ]
    }
  },

  "add-input-forgiveness": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "pondspawn:super-jump_input-forgiveness",
      "operation": "set",
      "change": 10
    },
    "condition": {
      "type": "origins:resource",
      "resource": "pondspawn:super-jump_super-jump-resource",
      "comparison": ">",
      "compare_to": 70
    }
  },

  "charge-jump-resource": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:change_resource",
          "resource": "pondspawn:super-jump_super-jump-resource",
          "operation": "add",
          "change": 1
        },
        {
          "type": "origins:if_else",
          "condition": {
            "type": "origins:all_of",
            "conditions": [
              {
                "type": "origins:resource",
                "resource": "pondspawn:super-jump_super-jump-resource",
                "comparison": ">",
                "compare_to": 50
              },
              {
                "type": "origins:resource",
                "resource": "pondspawn:super-jump_super-jump-resource",
                "comparison": "<",
                "compare_to": 80
              }
            ]
          },
          "if_action": {
            "type": "pondspawn:execute_commands",
            "commands": [
              "particle pondspawn:frog_jump_particle ~ ~ ~ 0 0 0 1 2 force",
              "playsound minecraft:block.bubble_column.upwards_ambient ambient @s ~ ~ ~ 0.1 1"
            ]
          }
        }
      ]
    },
    "condition": {
      "type": "apoli:all_of",
      "conditions": [
        {"type": "origins:sneaking"},
        {
          "type": "origins:nbt",
          "nbt": "{OnGround:1b}"
        }
      ]
    }
  },

  "super-jump": {
    "type": "origins:active_self",
    "key": {
      "key": "key.jump"
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "pondspawn:execute_commands",
          "commands": [
            "tag @s add super_jump",
            "schedule function pondspawn:jump 2t"
          ]
        },
        {
          "type": "origins:change_resource",
          "resource": "pondspawn:jump-effect_resource",
          "operation": "add",
          "change": 100
        },
        {
          "type": "origins:change_resource",
          "resource": "pondspawn:moisture",
          "operation": "add",
          "change": -40
        }
      ]
    },
    "condition": {
      "type": "origins:all_of",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "pondspawn:super-jump_input-forgiveness",
          "comparison": ">",
          "compare_to": 0
        },
        {
          "type": "origins:resource",
          "resource": "pondspawn:long-jump_w-pressed",
          "comparison": "==",
          "compare_to": 0
        }
      ]
    }
  }
}