{
  "type": "origins:multiple",

  "name": "Small Ancestors",
  "description": "Your ancestors who evolved from frogs got a bit of height compared to the common frog. But they, and you, are still really small.",

  "badges": [
    {
      "type": "origins:tooltip",
      "sprite": "origins:textures/gui/badge/info.png",
      "text": "You are 1.5 Blocks tall."
    }
  ],


  "scale": {
    "type": "origins:action_on_callback",
    "entity_action_chosen": {
          "type": "origins:execute_command",
          "command": "attribute @s minecraft:generic.scale base set 0.66"
    },
    "entity_action_lost": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "attribute @s minecraft:generic.scale base set 1.0"
        }
      ]
    }
  }


}