{
  "type": "origins:multiple",

  "pressed": {
    "type": "origins:resource",
    "min": 0,
    "max": 3,
    "start_value": 0,
    "hud_render": {
      "should_render": false
    }
  },

  "on-press": {
    "type": "origins:active_self",
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "apoli:change_resource",
          "resource": "pondspawn:tongue-release_pressed",
          "change": 3,
          "operation": "set"
        },
        {
          "type": "apoli:change_resource",
          "resource": "pondspawn:tongue-pull_pressed",
          "change": 3,
          "operation": "set"
        }
      ]
    },
    "key": {
      "key": "key.origins.secondary_active",
      "continuous": true
    }
  },


  "not-pressed": {
    "type": "origins:action_over_time",
    "interval": 1,

    "entity_action": {
      "type": "apoli:change_resource",
      "resource": "pondspawn:tongue-pull_pressed",
      "change": -1,
      "operation": "add"
    },

    "condition": {
      "type": "apoli:resource",
      "resource": "pondspawn:tongue-pull_pressed",
      "comparison": ">",
      "compare_to": 0
    }
  },


  "pull":{
    "type": "active_self",

    "entity_action": {
      "type": "pondspawn:execute_commands",
      "commands": [
        "tongue @s",
        "changeTongue @s pull",
        "playsound minecraft:entity.frog.tongue player @s ~ ~ ~ 1000"
      ]
    },

    "key": {
      "key": "key.origins.secondary_active",
      "continuous": false
    }


  },

  "name": "§e§nTongue Pull",
  "description": "Launch your stick tongue and pull yourself towards it, if you are heavier that the entity you are pulling you are going to pull itself towards you instead.",


  "badges": [
    {
      "type": "origins:tooltip",
      "sprite": "origins:textures/gui/badge/active.png",
      "text": "Press and hold secondary while looking at a block or entity to activate;"
    },
    {
      "type": "origins:tooltip",
      "sprite": "origins:textures/gui/badge/info.png",
      "text": "Hold shift to loose the tongue while pulling yourself."
    }
  ]

}