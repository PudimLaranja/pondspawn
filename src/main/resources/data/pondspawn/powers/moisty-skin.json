{
  "type": "origins:multiple",

  "moisture-process": {
    "type": "origins:action_over_time",
    "interval": 10,
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "pondspawn:thirst_handler",
          "resource": "pondspawn:moisture",
          "reduce_on": [
            {
              "value": 20,
              "condition": {"type": "origins:on_fire"}
            },
            {
              "value": 5,
              "condition": {
                "type": "origins:biome",
                "condition": {
                  "type": "origins:temperature",
                  "comparison": ">=",
                  "compare_to": 1
                }
              }
            },
            {
              "value": 3,
              "condition": {
                "type": "pondspawn:armor_equipped",
                "piece": "helmet"
              }
            },
            {
              "value": 10,
              "condition": {
                "type": "pondspawn:armor_equipped",
                "piece": "chestplate"
              }
            },
            {
              "value": 4,
              "condition": {
                "type": "pondspawn:armor_equipped",
                "piece": "leggings"
              }
            },
            {
              "value": 3,
              "condition": {
                "type": "pondspawn:armor_equipped",
                "piece": "boots"
              }
            }
          ],
          "increase_on": [
            {
              "value": 400,
              "condition": {
                "type": "apoli:any_of",
                "conditions": [
                  {"type": "origins:in_rain"},
                  {
                    "type": "origins:fluid_height",
                    "fluid": "minecraft:water",
                    "comparison": ">",
                    "compare_to": 0
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "origins:change_resource",
          "resource": "pondspawn:moisture",
          "operation": "add",
          "change": -1
        }
      ]
    }
  },

  "moisture50": {
    "type":"origins:action_over_time",
    "entity_action": {
      "type": "origins:execute_command",
      "command": "effect give @s minecraft:slowness 2 1 true"
    },
    "condition": {
      "type": "origins:resource",
      "resource": "pondspawn:moisture",
      "comparison": "<",
      "compare_to": 1250
    }
  },

  "moisture25": {
    "type":"origins:action_over_time",
    "entity_action": {
      "type": "origins:execute_command",
      "command": "effect give @s minecraft:weakness 2 1 true"
    },
    "condition": {
      "type": "origins:resource",
      "resource": "pondspawn:moisture",
      "comparison": "<",
      "compare_to": 625
    }
  },

  "suffocate": {
    "type": "origins:water_breathing",
    "condition": {
      "type": "origins:resource",
      "resource": "pondspawn:moisture",
      "comparison": "==",
      "compare_to": 0
    }
  },

  "on-death": {
    "type": "origins:action_on_callback",
    "entity_action_respawned": {
      "type": "origins:execute_command",
      "command": "resource set @s pondspawn:moisture 2500"
    }
  },

  "on_drink_water": {
    "type": "apoli:action_on_item_use",
    "trigger": "finish",
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "pondspawn:moisture",
      "operation": "add",
      "change": 600
    },
    "item_condition": {
      "type": "apoli:ingredient",
      "ingredient": "minecraft:potion"
    }
  },

  "on_drink": {
    "type": "origins:action_on_item_use",
    "trigger": "finish",
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "pondspawn:moisture",
      "operation": "add",
      "change": 400
    },
    "item_condition": {
      "type": "origins:ingredient",
      "ingredient": "minecraft:honey_bottle"
    }
  },


  "fire_damage": {
    "type": "origins:action_when_damage_taken",
    "cooldown": 0,
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "pondspawn:moisture",
      "operation": "add",
      "change": -20
    },
    "damage_condition":{
      "type": "origins:any_of",
      "conditions": [
        {
          "type": "origins:name",
          "name": "fireball"
        },
        {
          "type": "origins:name",
          "name": "fireworks"
        },
        {
          "type": "origins:name",
          "name": "lava"
        },
        {
          "type": "origins:name",
          "name": "explosion"
        },
        {
          "type": "origins:name",
          "name": "hotFloor"
        },
        {
          "type": "origins:name",
          "name": "inFire"
        },
        {
          "type": "origins:name",
          "name": "onFire"
        }
      ]
    }
  },

  "name": "Moisty skin",
  "description": "Like any amphibious creature you breath through your skin and it needs to be moist all the time so you can breath"
}